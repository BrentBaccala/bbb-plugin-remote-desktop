#!/bin/bash
set -e

BBB_WEB_PROPS=/etc/bigbluebutton/bbb-web.properties
BBB_PROPS=/usr/share/bbb-web/WEB-INF/classes/bigbluebutton.properties

case "$1" in
    configure)
        if [ -f "$BBB_WEB_PROPS" ]; then
            # Get the server URL from BBB's own config
            SERVER_URL=$(grep -oP '(?<=^bigbluebutton.web.serverURL=).*' "$BBB_PROPS" 2>/dev/null || echo "")
            if [ -z "$SERVER_URL" ]; then
                echo "bbb-plugin-remote-desktop: WARNING: could not determine server URL from $BBB_PROPS"
                echo "bbb-plugin-remote-desktop: please set pluginManifests manually in $BBB_WEB_PROPS"
                exit 0
            fi
            MANIFEST_URL="${SERVER_URL}/plugins/remote-desktop/manifest.json"

            # Read existing pluginManifests value
            CURRENT=$(grep -oP '(?<=^pluginManifests=).*' "$BBB_WEB_PROPS" 2>/dev/null || echo "")

            # Check if our manifest is already listed
            if echo "$CURRENT" | grep -q "remote-desktop/manifest.json"; then
                echo "bbb-plugin-remote-desktop: manifest already configured"
            elif [ -z "$CURRENT" ] || [ "$CURRENT" = "[]" ]; then
                # No existing plugins — set ours
                sed -i '/^pluginManifests=/d' "$BBB_WEB_PROPS"
                echo "pluginManifests=[{\"url\":\"$MANIFEST_URL\"}]" >> "$BBB_WEB_PROPS"
                echo "bbb-plugin-remote-desktop: added manifest to bbb-web.properties"
            else
                # Append to existing plugin list
                # Remove trailing ] and add our entry
                NEW=$(echo "$CURRENT" | sed "s/]$/,{\"url\":\"$MANIFEST_URL\"}]/")
                sed -i "s|^pluginManifests=.*|pluginManifests=$NEW|" "$BBB_WEB_PROPS"
                echo "bbb-plugin-remote-desktop: appended manifest to existing pluginManifests"
            fi
        fi
        ;;
esac

#DEBHELPER#
