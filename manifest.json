{
  "requiredSdkVersion": "~0.0.84",
  "name": "RemoteDesktop",
  "javascriptEntrypointUrl": "RemoteDesktop.js",
  "localesBaseUrl": "locales",
  "dataChannels": [
    {
      "name": "remoteDesktop",
      "pushPermission": ["moderator", "presenter"],
      "replaceOrDeletePermission": ["creator", "moderator"]
    }
  ],
  "settingsSchema": [
    {
      "name": "remoteDesktopUrl",
      "type": "string",
      "required": false,
      "defaultValue": ""
    },
    {
      "name": "startLocked",
      "type": "boolean",
      "required": false,
      "defaultValue": true
    },
    {
      "name": "buttons",
      "type": "json",
      "required": false,
      "defaultValue": []
    }
  ]
}
